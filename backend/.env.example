# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────

# Server
PORT=3000

# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AeroDataBox via RapidAPI — get from rapidapi.com/aedbx-aedbx/api/aerodatabox
AERODATABOX_API_KEY=your-rapidapi-key-here

# OpenSky Network — free tier, no key needed (optional basic auth for higher limits)
# OPENSKY_USERNAME=your-opensky-username
# OPENSKY_PASSWORD=your-opensky-password

# OpenWeatherMap — free tier, get from openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key-here

# Apple Push Notifications (APNs)
# Get the .p8 key file from Apple Developer Portal > Certificates, Identifiers & Profiles
# Place the file at ./apns-key.p8
APNS_KEY_ID=your-10-char-key-id
APNS_TEAM_ID=your-10-char-team-id
APNS_BUNDLE_ID=com.yourname.flighttracker

# Set to "production" for the App Store build, "development" for Simulator/TestFlight
APNS_ENVIRONMENT=development
